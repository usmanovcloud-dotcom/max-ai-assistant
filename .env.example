APP_DATA_DIR=/data
APP_DATABASE_PATH=/data/assistant.sqlite3
MAX_SESSION_PATH=/data/max-session.sqlite3
MAX_QR_PATH=/data/login.svg
MAX_QR_STATUS_PATH=/data/qr-status.json
MAX_2FA_FILE=/run/secrets/max-2fa.txt
CLAIM_COMMAND_PATH=/data/claim-command.txt
LOG_LEVEL=INFO
CLAIM_TTL_SECONDS=900
MAX_MESSAGE_CHARS=3500
PYMAX_TELEMETRY_ENABLED=false
MAX_RECONNECT_DELAY=2.0
MAX_LOCALE=ru
MAX_TIMEZONE=Asia/Yekaterinburg
MAX_WEB_HEADER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36
MAX_ATTACHMENT_COUNT=5
MAX_ATTACHMENT_BYTES=20971520
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY_FILE=/run/secrets/openai-api-key.txt
LLM_MODEL=gpt-5.6-luna
LLM_TIMEOUT=60
LLM_DAILY_LIMIT=50
LLM_DAILY_TOKEN_LIMIT=100000
LLM_MAX_OUTPUT_TOKENS=1200
LLM_MAX_RETRIES=2
LLM_HISTORY_MESSAGES=30
LLM_MAX_INPUT_CHARS=24000
LLM_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LLM_TIMEZONE_OFFSET_MINUTES=300
WEB_HOST=127.0.0.1
WEB_PORT=8765
WEB_AUTOSTART_AI=true
OPENAI_MONTHLY_BUDGET_USD=10
CONTAINER_MODE=false
